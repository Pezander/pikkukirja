# Copy to .env and fill in values
DATABASE_URL="file:./data/prod.db"

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=""

# Encrypts TOTP secrets at rest (AES-256-GCM). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Once set, keep this key safe — losing it locks out all 2FA users.
TOTP_ENCRYPTION_KEY=""
AUTH_TRUST_HOST=true

# Optional: SMTP for sending invoices by email.
# These env vars take priority over the UI settings (Admin → SMTP-asetukset).
# Leave commented out to configure SMTP through the admin UI instead.
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_USER="your@email.com"
# SMTP_PASS="your-smtp-password"
# SMTP_FROM="Yhdistyksen nimi <your@email.com>"
